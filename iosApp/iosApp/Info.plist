<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!--
	  Launch Screen 定義。Xcode 自動生成 (UILaunchScreen_Generation) を切り、
	  本 plist の値を使う。Figma node 383-18577 の実アセット差し替えは別途。
	  SwiftUI 側 SplashView と背景色・ロゴが揃っていないと切替時にチラつくので注意。
	-->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>FujuSplashBackground</string>
		<key>UIImageName</key>
		<string>FujuLogo</string>
		<key>UIImageRespectsSafeAreaInsets</key>
		<true/>
	</dict>
</dict>
</plist>
